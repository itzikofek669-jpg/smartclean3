rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ── משתמשים ──────────────────────────────────────────────────────────────
    match /users/{userId} {
      // כל משתמש מחובר יכול לקרוא פרופילים (להצגת מנקים)
      allow read: if request.auth != null;
      // יצירה: רק המשתמש עצמו (מיד אחרי הרשמה)
      allow create: if request.auth != null && request.auth.uid == userId;
      // עדכון: המשתמש עצמו, או כל משתמש מחובר שמעדכן אך ורק שדות דירוג (ביקורת מלקוח)
      allow update: if request.auth != null && (
        request.auth.uid == userId ||
        request.resource.data.diff(resource.data).affectedKeys().hasOnly(['rating', 'reviewCount', 'reviews'])
      );
      // מחיקה: רק אדמין (למחיקת מנקים/לקוחות ממסך הניהול)
      allow delete: if request.auth != null && request.auth.token.email == 'cleantouchapp@gmail.com';

      // ביקורות תת-אוסף
      match /reviews/{reviewId} {
        allow read: if request.auth != null;
        allow create: if request.auth != null;
        allow update, delete: if false;
      }
    }

    // ── הזמנות ────────────────────────────────────────────────────────────────
    match /bookings/{bookingId} {
      allow read:   if request.auth != null;
      allow create: if request.auth != null;
      allow update: if request.auth != null;
      allow delete: if false;
    }

    // ── צ'אטים ────────────────────────────────────────────────────────────────
    match /chats/{chatId} {
      allow read, write: if request.auth != null;

      match /messages/{messageId} {
        allow read, write: if request.auth != null;
      }
    }

    // ── הודעות תמיכה ──────────────────────────────────────────────────────────
    match /supportMessages/{msgId} {
      allow read, write: if request.auth != null;
    }

    // ── בקשות ניקוי דחוף ──────────────────────────────────────────────────────
    // לקוח יוצר בקשה, כל המנקים קוראים בקשות פתוחות, מנקה מעדכן/משבץ,
    // והאפליקציה מוחקת אוטומטית בקשות שפג תוקפן
    match /urgentRequests/{reqId} {
      allow read:   if request.auth != null;
      allow create: if request.auth != null;
      allow update: if request.auth != null;
      allow delete: if request.auth != null;
    }

    // ── דיווחים (באגים / דיווח על משתמש) ─────────────────────────────────────
    match /reports/{reportId} {
      allow read:   if request.auth != null;
      allow create: if request.auth != null;
      allow update: if request.auth != null;
      allow delete: if request.auth != null;
    }

    // ── בקשות ביטוח ───────────────────────────────────────────────────────────
    match /insuranceRequests/{reqId} {
      allow read:   if request.auth != null;
      allow create: if request.auth != null;
      allow update: if request.auth != null;
      allow delete: if false;
    }

    // ── קודי הנחה ─────────────────────────────────────────────────────────────
    match /promoCodes/{promoId} {
      allow read:  if request.auth != null;
      allow write: if request.auth != null &&
                      request.auth.token.email in [
                        'cleantouchapp@gmail.com'
                      ];
    }

    // ── הגדרות אדמין ──────────────────────────────────────────────────────────
    match /settings/{settingId} {
      allow read:  if request.auth != null;
      allow write: if request.auth != null &&
                      request.auth.token.email in [
                        'cleantouchapp@gmail.com'
                      ];
    }

    // ── ברירת מחדל — חסום הכל ───────────────────────────────────────────────
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
